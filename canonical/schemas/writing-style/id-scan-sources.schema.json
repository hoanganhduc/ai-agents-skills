{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Writing style ID scan sources",
  "type": "object",
  "required": ["schema_version", "generated_for_release", "sources"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"const": "writing-style.id-scan-sources.v1"},
    "generated_for_release": {"type": "string"},
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["artifact_class", "path", "id_fields"],
        "additionalProperties": false,
        "properties": {
          "artifact_class": {"type": "string"},
          "path": {"type": "string"},
          "id_fields": {"type": "array", "items": {"type": "string"}}
        }
      }
    }
  }
}
