{
  "schema_version": "openclaw.fixture-catalog.v1",
  "fixture_catalog_id": "openclaw_phase0_adversarial",
  "purpose": "Define Phase 0 fake-root fixture classes without adding a production scanner.",
  "source_root_fixtures": [
    {
      "fixture_id": "absent-root",
      "purpose": "Inventory reports absent explicit root without falling back to ~/.openclaw.",
      "expected_source_writes": false
    },
    {
      "fixture_id": "sensitive-root",
      "purpose": "Denied categories are counted by sanitized reason code only.",
      "denied_categories": [
        "secret",
        "auth",
        "provider-config",
        "log-history-memory",
        "scheduler-hook",
        "private-workspace",
        "browser-gateway",
        "database-cache"
      ],
      "expected_content_reads": false,
      "canary_secret_label": "<CANARY_SECRET>"
    },
    {
      "fixture_id": "path-trap-root",
      "purpose": "Reject symlink, hardlink, traversal, mount, reparse, and special-file escapes.",
      "path_cases": [
        "symlink-prefix",
        "symlink-loop",
        "hardlink-to-denied-file",
        "relative-parent-traversal",
        "windows-junction",
        "macos-alias",
        "device-file",
        "fifo",
        "socket"
      ]
    },
    {
      "fixture_id": "malformed-root",
      "purpose": "Malformed configs produce sanitized reason codes and no raw parse excerpts.",
      "expected_diagnostics": "reason-code-only"
    }
  ],
